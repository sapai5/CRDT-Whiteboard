# ── Shared ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=debug

# ── Auth Service ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Persistence Service ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/whiteboard.db   # swap for postgres in prod
# DATABASE_URL=postgresql://user:pass@localhost:5432/whiteboard

# ── CRDT Sync Service ─────────────────────────────────────────────────────────
MAX_CONNECTIONS_PER_ROOM=50
CRDT_SNAPSHOT_INTERVAL_SECONDS=30
